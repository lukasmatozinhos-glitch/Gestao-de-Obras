rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Hardened Admin Helper
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email in ["lukasmatozinhos3@gmail.com", "lucas.m.santos@axia.com.br", "lucas.m.santos@axia.com.br"] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accessLevel in ['Administrador de Sistema', 'Gestor'])
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function isValidEmail(email) {
      return email is string && email.size() > 5;
    }

    function isValidUrl(url) {
      return url is string && url.size() > 0;
    }

    // ===============================================================
    // Domain Validators (The "Anti-Update-Gap")
    // ===============================================================

    function isValidUser(data) {
      return data.id is string && 
             data.name is string && 
             data.email is string;
    }

    function isValidProject(data) {
      return data.id is string && data.name is string &&
             data.client is string && data.status is string;
    }

    function isValidPhotoReport(data) {
      return data.id is string && data.projectId is string &&
             data.url is string && 
             data.date is string;
    }

    function isValidBulletin(data) {
      return data.id is string && data.projectId is string &&
             data.projectName is string && data.contractNumber is string &&
             data.value is number && data.date is string &&
             data.status is string;
    }

    function isValidAddendum(data) {
      return data.id is string && data.projectId is string &&
             data.number is string && data.description is string &&
             data.value is number && data.isApproved is bool &&
             data.createdAt is string;
    }

    function isValidScheduleActivity(data) {
      return data.id is string && 
             data.projectId is string && 
             data.name is string &&
             data.startDate is string &&
             data.endDate is string &&
             data.progress is number &&
             data.status is string &&
             data.order is number;
    }

    function isValidPlanningActivity(data) {
      return data.id is string && 
             data.projectId is string && 
             data.name is string &&
             data.startMonth is number && data.startYear is number &&
             data.endMonth is number && data.endYear is number &&
             data.color is string && data.order is number;
    }

    function isValidFiscalPlanningActivity(data) {
      return data.id is string && 
             data.name is string &&
             data.startMonth is number && data.startYear is number &&
             data.endMonth is number && data.endYear is number &&
             data.color is string && data.order is number;
    }

    function isValidRCRequest(data) {
      return data.projectId is string && 
             data.projectName is string &&
             data.requestDate is string &&
             data.status in ['requested', 'pending', 'received', 'returned'] &&
             (data.value is number || !('value' in data)) &&
             (!('signedBulletin' in data) || (
               data.signedBulletin.name is string &&
               data.signedBulletin.url is string
             ));
    }

    function isValidTravel(data) {
      return data.id is string && 
             data.name is string && 
             data.cost is number && 
             data.inspector is string && 
             data.origin is string && 
             data.destination is string && 
             data.startDate is string && 
             data.endDate is string && 
             data.monthYear is string;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidProject(request.resource.data);
      allow update: if isAuthenticated() && isValidProject(request.resource.data);
      allow delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /measurements/{measurementId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /attachments/{attachmentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /statusUpdates/{updateId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /photoReports/{photoId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidPhotoReport(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /measurementBulletins/{bulletinId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidBulletin(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /projectAddendums/{addendumId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidAddendum(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /scheduleActivities/{activityId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidId(activityId) && 
                              isValidScheduleActivity(request.resource.data);
      allow delete: if isAdmin();
    }

    match /planningActivities/{activityId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidId(activityId) && 
                              isValidPlanningActivity(request.resource.data);
      allow delete: if isAdmin();
    }

    match /fiscalPlanningActivities/{activityId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidId(activityId) && 
                              isValidFiscalPlanningActivity(request.resource.data);
      allow delete: if isAdmin();
    }

    match /consumptionRCRequests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidRCRequest(request.resource.data);
      allow update: if isAuthenticated() && (isAdmin() || (isOwner(resource.data.createdBy) && isValidRCRequest(request.resource.data)));
      allow delete: if isAdmin() || isOwner(resource.data.createdBy);
    }

    match /travels/{travelId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidId(travelId) && isValidTravel(request.resource.data);
      allow delete: if isAuthenticated();
    }
  }
}
