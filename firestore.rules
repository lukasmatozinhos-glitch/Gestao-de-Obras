rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // 1. Global Safety Net (Deny-All by Default)
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // 2. Global Helper Primitives & Boundary Limits
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isNumeric(val) {
      return val is int || val is float;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Hardened Admin Helper: checks token email list OR Firestore user role hierarchy
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email in ["lukasmatozinhos3@gmail.com", "lucas.m.santos@axia.com.br", "ricardo.silva@axiaenergia.com.br"] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accessLevel in ['Administrador de Sistema', 'Gestor'])
      );
    }

    // Relational Project Governance Helper for Work Segregation (Obra Isolation)
    function isAuthorizedForProject(projectId) {
      return isAuthenticated() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('projectId', '') == projectId ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('projectId', '') == ''))
      );
    }

    // ===============================================================
    // 3. Validation Blueprints (Anti-Update-Gap / Precise Schemas)
    // ===============================================================
    function isValidUser(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 128 &&
             data.email is string && data.email.size() <= 128 &&
             (!('role' in data) || (data.role is string && data.role.size() <= 128)) &&
             (!('phone' in data) || (data.phone is string && data.phone.size() <= 128)) &&
             (!('accessLevel' in data) || (data.accessLevel is string && data.accessLevel.size() <= 128));
    }

    function isValidProject(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 256 &&
             data.client is string && data.client.size() <= 128 &&
             data.status is string && data.status.size() <= 64;
    }

    function isValidPhotoReport(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.projectId is string && data.projectId.size() <= 128 &&
             data.url is string && data.url.size() <= 1048576 && // 1MB limit check
             data.date is string && data.date.size() <= 64;
    }

    function isValidBulletin(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.projectId is string && data.projectId.size() <= 128 &&
             data.projectName is string && data.projectName.size() <= 256 &&
             data.contractNumber is string && data.contractNumber.size() <= 128 &&
             isNumeric(data.value) && data.value >= 0 &&
             data.date is string && data.date.size() <= 64 &&
             data.status is string && data.status.size() <= 64;
    }

    function isValidMeasurement(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.projectId is string && data.projectId.size() <= 128 &&
             data.projectName is string && data.projectName.size() <= 256 &&
             data.date is string && data.date.size() <= 64 &&
             isNumeric(data.value) && data.value >= 0 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 1024)) &&
             data.status in ['pending', 'approved', 'paid'] &&
             (!('createdBy' in data) || (data.createdBy is string && data.createdBy.size() <= 128)) &&
             (!('creatorName' in data) || (data.creatorName is string && data.creatorName.size() <= 256));
    }

    function isValidAddendum(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.projectId is string && data.projectId.size() <= 128 &&
             data.number is string && data.number.size() <= 128 &&
             data.description is string && data.description.size() <= 1024 &&
             isNumeric(data.value) && data.value >= 0 &&
             data.isApproved is bool &&
             data.createdAt is string && data.createdAt.size() <= 64;
    }

    function isValidScheduleActivity(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.projectId is string && data.projectId.size() <= 128 &&
             data.name is string && data.name.size() <= 256 &&
             data.startDate is string && data.startDate.size() <= 64 &&
             data.endDate is string && data.endDate.size() <= 64 &&
             isNumeric(data.progress) && data.progress >= 0 && data.progress <= 100 &&
             data.status is string && data.status.size() <= 64 &&
             isNumeric(data.order);
    }

    function isValidPlanningActivity(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.projectId is string && data.projectId.size() <= 128 &&
             data.name is string && data.name.size() <= 256 &&
             isNumeric(data.startMonth) && isNumeric(data.startYear) &&
             isNumeric(data.endMonth) && isNumeric(data.endYear) &&
             data.color is string && data.color.size() <= 64 &&
             isNumeric(data.order);
    }

    function isValidFiscalPlanningActivity(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 256 &&
             isNumeric(data.startMonth) && isNumeric(data.startYear) &&
             isNumeric(data.endMonth) && isNumeric(data.endYear) &&
             data.color is string && data.color.size() <= 64 &&
             isNumeric(data.order);
    }

    function isValidRCRequest(data) {
      return data.projectId is string && data.projectId.size() <= 128 &&
             data.projectName is string && data.projectName.size() <= 256 &&
             data.requestDate is string && data.requestDate.size() <= 64 &&
             data.status in ['requested', 'pending', 'received', 'returned', 'canceled'] &&
             (isNumeric(data.value) || !('value' in data)) &&
             (!('signedBulletin' in data) || (
               data.signedBulletin.name is string && data.signedBulletin.name.size() <= 256 &&
               data.signedBulletin.url is string && data.signedBulletin.url.size() <= 1048576
             ));
    }

    function isValidTravel(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 256 &&
             isNumeric(data.cost) && data.cost >= 0 &&
             data.inspector is string && data.inspector.size() <= 256 &&
             data.origin is string && data.origin.size() <= 256 &&
             data.destination is string && data.destination.size() <= 256 &&
             data.startDate is string && data.startDate.size() <= 64 &&
             data.endDate is string && data.endDate.size() <= 64 &&
             data.monthYear is string && data.monthYear.size() <= 32;
    }

    function isValidFieldInspector(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 256 &&
             data.createdAt is string && data.createdAt.size() <= 64;
    }

    function isValidDailyWorkReport(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.projectId is string && data.projectId.size() <= 128 &&
             data.projectName is string && data.projectName.size() <= 256 &&
             data.date is string && data.date.size() <= 64 &&
             data.weatherMorning is string &&
             data.weatherAfternoon is string &&
             data.workConditions is string &&
             data.servicesDone is string &&
             data.createdAt is string &&
             data.createdBy is string &&
             data.creatorName is string;
    }

    function isValidAuditLog(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.userName is string && data.userName.size() <= 256 &&
             data.timestamp is string && data.timestamp.size() <= 64 &&
             data.operation is string && data.operation.size() <= 64 &&
             data.entity is string && data.entity.size() <= 64 &&
             data.recordId is string && data.recordId.size() <= 128 &&
             data.status is string && data.status.size() <= 64 &&
             data.userAgent is string && data.userAgent.size() <= 1024 &&
             (!('details' in data) || (data.details is string && data.details.size() <= 8192));
    }

    // ===============================================================
    // 4. Match Rules per Collection Path (Zero-Trust Configuration)
    // ===============================================================

    // Audit Logs: STRICTLY IMUTABLE (No updates/deletions permitted)
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isValidAuditLog(incoming());
      allow update, delete: if false;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isValidUser(incoming()) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(incoming()) && (isOwner(userId) || isAdmin()) && (
        // Forbid standard users from promoting their own access levels
        isAdmin() || (!incoming().diff(existing()).affectedKeys().hasAny(['accessLevel', 'role']))
      );
      allow delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated() && isAuthorizedForProject(projectId);
      allow create: if isAdmin() && isValidProject(incoming());
      allow update: if isAuthorizedForProject(projectId) && isValidProject(incoming()) && (
        isAdmin() || (!incoming().diff(existing()).affectedKeys().hasAny(['budget', 'client', 'contractNumber', 'name']))
      );
      allow delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow read: if isAuthenticated() && isAuthorizedForProject(existing().projectId);
      allow write: if isAdmin();
    }

    match /measurements/{measurementId} {
      allow read: if isAuthenticated() && isAuthorizedForProject(existing().projectId);
      allow create: if isAuthenticated() && isValidMeasurement(incoming()) && isAuthorizedForProject(incoming().projectId);
      allow update: if isAuthenticated() && isAuthorizedForProject(incoming().projectId) && isValidMeasurement(incoming()) && (
        isAdmin() || (!incoming().diff(existing()).affectedKeys().hasAny(['status']) || incoming().status == existing().status)
      );
      allow delete: if isAdmin();
    }

    match /attachments/{attachmentId} {
      allow read: if isAuthenticated() && isAuthorizedForProject(existing().projectId);
      allow create: if isAuthenticated() && isAuthorizedForProject(incoming().projectId);
      allow update: if isAdmin();
      allow delete: if isAdmin() || (isAuthenticated() && isAuthorizedForProject(existing().projectId));
    }

    match /statusUpdates/{updateId} {
      allow read: if isAuthenticated() && isAuthorizedForProject(existing().projectId);
      allow create: if isAuthenticated() && isAuthorizedForProject(incoming().projectId);
      allow update, delete: if isAdmin();
    }

    match /photoReports/{photoId} {
      allow read: if isAuthenticated() && isAuthorizedForProject(existing().projectId);
      allow create: if isAuthenticated() && isValidPhotoReport(incoming()) && isAuthorizedForProject(incoming().projectId);
      allow update, delete: if isAdmin();
    }

    match /measurementBulletins/{bulletinId} {
      allow read: if isAuthenticated() && isAuthorizedForProject(existing().projectId);
      allow create: if isAuthenticated() && isValidBulletin(incoming()) && isAuthorizedForProject(incoming().projectId);
      allow update: if isAuthorizedForProject(incoming().projectId) && (
        isAdmin() || (!incoming().diff(existing()).affectedKeys().hasOnly(['status']))
      );
      allow delete: if isAdmin();
    }

    match /projectAddendums/{addendumId} {
      allow read: if isAuthenticated() && isAuthorizedForProject(existing().projectId);
      allow create: if isAuthenticated() && isValidAddendum(incoming()) && isAuthorizedForProject(incoming().projectId);
      allow update, delete: if isAdmin();
    }

    match /scheduleActivities/{activityId} {
      allow read: if isAuthenticated() && isAuthorizedForProject(existing().projectId);
      allow create, update: if isAuthenticated() && isValidId(activityId) && 
                              isValidScheduleActivity(incoming()) && 
                              isAuthorizedForProject(incoming().projectId);
      allow delete: if isAdmin();
    }

    match /planningActivities/{activityId} {
      allow read: if isAuthenticated() && isAuthorizedForProject(existing().projectId);
      allow create, update: if isAuthenticated() && isValidId(activityId) && 
                              isValidPlanningActivity(incoming()) && 
                              isAuthorizedForProject(incoming().projectId);
      allow delete: if isAdmin();
    }

    match /fiscalPlanningActivities/{activityId} {
      allow read: if isAuthenticated() && isAuthorizedForProject(existing().projectId);
      allow create, update: if isAuthenticated() && isValidId(activityId) && 
                              isValidFiscalPlanningActivity(incoming()) && 
                              isAuthorizedForProject(incoming().projectId);
      allow delete: if isAdmin();
    }

    match /consumptionRCRequests/{requestId} {
      allow read: if isAuthenticated() && isAuthorizedForProject(existing().projectId);
      allow create: if isAuthenticated() && isValidRCRequest(incoming()) && isAuthorizedForProject(incoming().projectId);
      allow update: if isAuthenticated() && isAuthorizedForProject(incoming().projectId) && (
        isAdmin() || (isOwner(existing().createdBy) && isValidRCRequest(incoming()) && !incoming().diff(existing()).affectedKeys().hasAny(['value']))
      );
      allow delete: if isAdmin() || (isAuthenticated() && isOwner(existing().createdBy));
    }

    match /travels/{travelId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidId(travelId) && isValidTravel(incoming());
      allow delete: if isAuthenticated();
    }

    match /fieldInspectors/{inspectorId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidId(inspectorId) && isValidFieldInspector(incoming());
      allow delete: if isAdmin();
    }

    match /dailyWorkReports/{reportId} {
      allow read: if isAuthenticated() && isAuthorizedForProject(existing().projectId);
      allow create, update: if isAuthenticated() && isValidId(reportId) && isValidDailyWorkReport(incoming()) && isAuthorizedForProject(incoming().projectId);
      allow delete: if isAdmin();
    }
  }
}
